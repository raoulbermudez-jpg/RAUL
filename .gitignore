# ===========================
# RAUL - Gitignore canónico
# ===========================
# Política:
# - Versionar sólo el "cerebro" del sistema: reglas, KB en texto, scripts y código.
# - Mantener fuera del repo: buzones operativos, raw sources, binarios pesados y archivo histórico.
# - Facilitar backups externos (05-archive) y mirrors (Drive) sin contaminar Git.

# ---------------------------
# 1) Buzones operativos / Inbox
# ---------------------------
# 01-inbox es hub de IO. Todo su contenido corriente se trata como operativo, no como estado del sistema.

01-inbox/01-owner-to-raul/
01-inbox/02-deliverables-to-owner/
01-inbox/03-raw-sources/

# Permitimos sólo documentación de estructura si algún día hubiera README.md
# (no hace falta regla extra: README.md nuevo se añadirá explícitamente con git add si lo necesitas).

# ---------------------------
# 2) Archivo histórico
# ---------------------------
# 05-archive se respalda aparte (NAS, disco externo, etc.) y no se versiona en Git.

05-archive/

# ---------------------------
# 3) Binarios pesados globales
# ---------------------------
# Regla general para evitar que entren PDFs, PPTX, imágenes pesadas, vídeo, audio, etc.
# Se aplican en todo el árbol (03-projects, 02-knowledge-base/assets, etc.).

*.pdf
*.pptx
*.ppt
*.doc
*.docx
*.xls
*.xlsx
*.xlsm
*.csv
*.ods

*.png
*.jpg
*.jpeg
*.gif
*.tif
*.tiff
*.bmp
*.webp
*.svgz

*.mp4
*.mov
*.m4v
*.avi
*.mkv
*.wmv

*.mp3
*.wav
*.flac
*.aac
*.ogg

*.zip
*.rar
*.7z
*.tar
*.gz

# ---------------------------
# 4) Excepción para specs en PDF
# ---------------------------
# Si alguna hoja técnica/specificación se decide mantener en PDF dentro de 02-knowledge-base/specs,
# esta regla permite añadirla explícitamente con git add.

!02-knowledge-base/**/specs/*.pdf

# ---------------------------
# 5) Archivos temporales y de editor
# ---------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# VSCode / IDEs
.vscode/
.idea/
*.code-workspace

# Python / entorno
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv/
venv/

# Logs y temporales genéricos
*.log
*.tmp
*.temp
*~
.~lock.*

# ---------------------------
# 6) Archivos de sesión y temporales de herramientas
# ---------------------------

# Configuración local de Claude Code (credenciales y permisos de sesión)
.claude/settings.local.json

# Archivos de encoding temporal (generados al subir binarios a Drive)
b64_*.txt

# Logs operativos de pipelines
pendrive_pipeline_stdout.txt

# ---------------------------
# 7) Otros directorios auxiliares
# ---------------------------
# Si en el futuro usas algún directorio de build o caché, se listaría aquí.
# Por ahora RAUL es local-first sin builds, así que no añadimos más.